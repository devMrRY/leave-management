{
  "name": "notification-service",
  "version": "1.0.0",
  "type": "module",
  "description": "Notification microservice for event-driven architecture.",
  "main": "dist/app.js",
  "scripts": {
    "start": "node --loader tsconfig-paths/register.js dist/app.js",
    "dev": "tsx src/app.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "@myorg/shared": "git+https://github.com/devMrRY/leave-management-shared.git",
    "dotenv": "^17.4.2",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "ts-node": "^10.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0"
  }
}

NODE_ENV=docker
PORT=7000

PEPPER=peppersalt
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=7d

# Consul Service Discovery
DOCKER_ENV=true
CONSUL_HOST=localhost
CONSUL_PORT=8500
SERVICE_NAME=notification-service

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
NODE_ENV=docker
PORT=4000
MONGO_URI=mongodb://mongo:27017/leave-service
PEPPER=peppersalt
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=7d

# Consul Service Discovery
DOCKER_ENV=true
CONSUL_HOST=consul
CONSUL_PORT=8500
SERVICE_NAME=leave-service
SERVICE_HOST=leave-service

USER-SERVICE_URL=http://user-service:3000

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
